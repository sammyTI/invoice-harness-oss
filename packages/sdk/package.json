{
  "name": "@invoice-harness/sdk",
  "version": "0.1.0",
  "description": "Typed TypeScript client for invoice-harness (請求書・帳票ハーネス) REST API. Zero dependencies, ESM + CJS.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "node --test"
  },
  "keywords": [
    "invoice",
    "invoice-harness",
    "請求書",
    "帳票",
    "cloudflare",
    "sdk",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sammyTI/invoice-harness-oss.git",
    "directory": "packages/sdk"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  }
}
