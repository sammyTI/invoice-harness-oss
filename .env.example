# ===== invoice-harness-oss =====
# Cloudflare account (used by wrangler during deploy)
CLOUDFLARE_ACCOUNT_ID=

# Resend (email send + dunning). Free tier: 3,000/mo, 100/day.
# Leave empty in Phase 0 (email is added in Phase 2).
RESEND_API_KEY=
MAIL_FROM="Invoice Harness <billing@example.com>"

# D1 database name (matches wrangler.toml). Created by the setup CLI.
D1_DATABASE_NAME=invoice_harness
